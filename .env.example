# Client-side (Vite exposes these to the browser — safe to be public,
# the anon key is protected by Row Level Security).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (Vercel Functions in /api). NEVER prefix these with
# VITE_ — that would bundle them into the client. Set these via
# `vercel env add <name>` or the Vercel dashboard, not by hand in a
# committed file.
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Base URL used for the Stripe success/cancel redirect. APP_BASE_URL takes
# priority; VITE_APP_URL is used as a fallback if that's what's already set.
APP_BASE_URL=http://localhost:5173
